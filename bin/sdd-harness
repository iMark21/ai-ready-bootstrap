#!/bin/bash
# sdd-harness — runtime-agnostic Spec-Driven Development harness CLI
#
# Lays down a canonical .ai/ layer plus root-level bootloaders for any AI runtime.
# Templates live in $REPO_ROOT/templates/ and are copied verbatim (with placeholder
# substitution) into the target repository.

set -euo pipefail

VERSION="1.0.0-alpha"

# Resolve $0 through any symlink chain so we can find templates/ relative to
# the real script location, not the symlink in ~/.local/bin/.
_self="$0"
while [ -h "$_self" ]; do
  _dir="$(cd -P "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  case "$_self" in
    /*) ;;
    *) _self="$_dir/$_self" ;;
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$_self")/.." && pwd)"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
unset _self _dir

# ---------- defaults ----------
COMMAND=""
TARGET_REPO=""
RUNTIMES="claude,codex"
FORCE=0
DRY_RUN=0
YES=0
NON_INTERACTIVE=0
INSTALL_HOOK=1
STACK=""
LIST_STACKS=0

# ---------- output helpers ----------
log()  { printf '%s\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
die()  { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
say()  { [ "$DRY_RUN" -eq 1 ] && printf '[dry-run] %s\n' "$*" || printf '%s\n' "$*"; }

usage() {
  cat <<EOF
sdd-harness $VERSION

Usage:
  sdd-harness <command> [repo-path] [options]

Commands:
  init            (Recommended) Detect repo state, route to install or standardize.
  audit           Inspect a repo and report the AI-layer state.
  install         Lay down a fresh .ai/ layer plus runtime bootloaders.
  standardize     Audit + back up existing AI files + install fresh.

Options:
  --repo PATH           Target repository path (defaults to current directory).
  --runtimes LIST       Comma-separated runtimes: claude, codex, cursor, copilot,
                        gemini, or 'all' (default: claude,codex).
  --stack STACK         Explicitly set stack (swift, android, python, node, go, rust, generic).
                        If omitted, defaults to 'generic'. Does not auto-detect.
  --list-stacks         Print supported stacks and exit.
  --force               Overwrite existing files where applicable.
  --dry-run             Print actions without writing files.
  --yes                 Do not ask for confirmation.
  --non-interactive     Fail instead of prompting for missing choices.
  --no-git-hook         Skip pre-commit-spec-check.sh installation.
  --version             Print version and exit.
  --help                Show this help.

Examples:
  sdd-harness init                              # inside the target repo
  sdd-harness init /path/to/repo
  sdd-harness audit /path/to/repo
  sdd-harness standardize /path/to/repo --yes

For the full manual, see .ai/ inside the target repo after install, or the
sdd-harness README at https://github.com/iMark21/sdd-harness.
EOF
}

# ---------- arg parsing ----------
if [ $# -eq 0 ]; then usage; exit 1; fi

COMMAND="$1"; shift || true

while [ $# -gt 0 ]; do
  case "$1" in
    --repo)            TARGET_REPO="${2:-}"; shift 2 ;;
    --runtimes)        RUNTIMES="${2:-}"; shift 2 ;;
    --stack)           STACK="${2:-}"; shift 2 ;;
    --list-stacks)     LIST_STACKS=1; shift ;;
    --force)           FORCE=1; shift ;;
    --dry-run)         DRY_RUN=1; shift ;;
    --yes)             YES=1; shift ;;
    --non-interactive) NON_INTERACTIVE=1; shift ;;
    --no-git-hook)     INSTALL_HOOK=0; shift ;;
    --version)         echo "$VERSION"; exit 0 ;;
    --help|-h)         usage; exit 0 ;;
    --*)               die "Unknown option: $1" ;;
    *)
      [ -z "$TARGET_REPO" ] && TARGET_REPO="$1" || die "Unexpected argument: $1"
      shift
      ;;
  esac
done

# Default target repo = pwd
[ -z "$TARGET_REPO" ] && TARGET_REPO="$(pwd)"
TARGET_REPO="$(cd "$TARGET_REPO" 2>/dev/null && pwd -P || die "Target does not exist: $TARGET_REPO")"

# Validate templates dir exists
[ -d "$TEMPLATES_DIR/.ai" ] || die "Templates directory missing: $TEMPLATES_DIR/.ai"

# ---------- runtime list normalization ----------
normalize_runtimes() {
  local input="$1"
  local lowered
  lowered="$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')"
  # Expand the 'all' alias before deduping.
  if printf '%s' "$lowered" | tr ',' '\n' | grep -qx 'all'; then
    lowered="claude,codex,cursor,copilot,gemini"
  fi
  printf '%s' "$lowered" | tr ',' '\n' | awk 'NF' | sort -u | paste -sd, -
}

RUNTIMES="$(normalize_runtimes "$RUNTIMES")"

valid_runtime() {
  case "$1" in
    claude|codex|cursor|copilot|gemini) return 0 ;;
    *) return 1 ;;
  esac
}

for r in $(echo "$RUNTIMES" | tr ',' ' '); do
  valid_runtime "$r" || die "Unsupported runtime in v$VERSION: $r (supported: claude, codex, cursor, copilot, gemini; or 'all')"
done

# ---------- stack validation ----------
valid_stack() {
  case "$1" in
    swift|android|python|node|go|rust|generic) return 0 ;;
    *) return 1 ;;
  esac
}

list_stacks() {
  log "Supported stacks:"
  log "  swift      Swift iOS"
  log "  android    Android"
  log "  python     Python"
  log "  node       Node.js"
  log "  go         Go"
  log "  rust       Rust"
  log "  generic    Generic/unspecified"
}

# Validate --stack flag if provided
if [ -n "$STACK" ]; then
  valid_stack "$STACK" || die "Unsupported stack: $STACK
Run 'sdd-harness init --list-stacks' to see available options."
fi

# ---------- detection ----------
AI_MARKERS=(
  ".ai"
  "CLAUDE.md"
  "AGENTS.md"
  "GEMINI.md"
  "AGENTLAYER.md"
  ".github/copilot-instructions.md"
  ".github/instructions"
  ".cursor/rules"
)

detect_existing_ai() {
  local repo="$1"
  for m in "${AI_MARKERS[@]}"; do
    if [ -e "$repo/$m" ]; then
      printf '%s\n' "$m"
    fi
  done
}

# ---------- file operations ----------
copy_file() {
  local src="$1" dst="$2"
  if [ "$DRY_RUN" -eq 1 ]; then
    say "copy $src -> $dst"
    return
  fi
  mkdir -p "$(dirname "$dst")"
  if [ -e "$dst" ] && [ "$FORCE" -ne 1 ]; then
    die "Destination exists: $dst (use --force or run 'sdd-harness standardize')"
  fi
  cp "$src" "$dst"
}

copy_tree() {
  local src="$1" dst="$2"
  if [ "$DRY_RUN" -eq 1 ]; then
    say "copy -R $src -> $dst"
    return
  fi
  mkdir -p "$dst"
  cp -R "$src/." "$dst/"
}

# ---------- install ----------
project_name() {
  basename "$1"
}

substitute_placeholders() {
  local file="$1" project="$2" branch="$3" stack="${4:-generic}"
  [ "$DRY_RUN" -eq 1 ] && return
  local prefix today
  prefix="$(printf '%s' "$project" | tr 'a-z' 'A-Z' | tr -cd 'A-Z' | cut -c1-3)"
  [ -z "$prefix" ] && prefix="X"
  today="$(date +%Y-%m-%d)"
  [ -z "$branch" ] && branch="develop"
  sed -i.bak \
    -e "s/{{PROJECT_NAME}}/$project/g" \
    -e "s/{{STORY_PREFIX}}/$prefix/g" \
    -e "s/{{TODAY}}/$today/g" \
    -e "s/{{GIT_BRANCH}}/$branch/g" \
    -e "s/{{STACK}}/$stack/g" \
    "$file"
  rm -f "${file}.bak"
}

# Dry-run the SDD hook's implementation-surface matching against tracked
# files. If SH_CODE_GLOBS, after SH_CODE_EXCLUDE_GLOBS, match nothing, the
# hook is mis-gated (it would pass code-only commits silently). Warn — do not
# fail. See SH-F4-110 / SH-F4-111.
glob_sanity_check() {
  local repo="$1"
  local config="$repo/.ai/hooks/config.sh"
  [ -f "$config" ] || { warn "no $config — skipping glob sanity check"; return; }

  # shellcheck source=/dev/null
  ( . "$config"
    if ! declare -p SH_CODE_EXCLUDE_GLOBS >/dev/null 2>&1; then
      SH_CODE_EXCLUDE_GLOBS=()
    fi

    match_globs() {
      local path="$1"
      shift
      local pattern
      for pattern in "$@"; do
        # shellcheck disable=SC2254
        case "$path" in $pattern) return 0 ;; esac
      done
      return 1
    }

    path_is_code() {
      local path="$1"
      if match_globs "$path" "${SH_CODE_EXCLUDE_GLOBS[@]}"; then
        return 1
      fi
      match_globs "$path" "${SH_CODE_GLOBS[@]}"
    }

    local matched=0 path
    while IFS= read -r path; do
      if path_is_code "$path"; then
        matched=1
      fi
      [ "$matched" -eq 1 ] && break
    done < <(git -C "$repo" ls-files 2>/dev/null)

    if [ "$matched" -eq 0 ]; then
      printf '\n'
      printf 'WARNING: the SDD pre-commit hook is mis-gated.\n' >&2
      printf '  No tracked file matches SH_CODE_GLOBS after SH_CODE_EXCLUDE_GLOBS.\n' >&2
      printf '  Feature commits would NOT be checked for a spec.\n' >&2
      printf '  Include globs: %s\n' "${SH_CODE_GLOBS[*]}" >&2
      printf '  Exclude globs: %s\n' "${SH_CODE_EXCLUDE_GLOBS[*]}" >&2
      printf '  This repo'\''s top-level entries:\n' >&2
      git -C "$repo" ls-files \
        | sed 's|/.*||' | sort -u \
        | grep -vE '^(\.ai|\.github|\.cursor)$' \
        | head -10 | sed 's/^/    /' >&2
      printf '  Edit .ai/hooks/config.sh -> SH_CODE_GLOBS / SH_CODE_EXCLUDE_GLOBS\n' >&2
      printf '  so at least one implementation path matches, then re-run .ai/hooks/install.sh.\n\n' >&2
    fi
  )
}

# Extract README ## TODO and ## Roadmap sections into BACKLOG.md rows.
# Returns count of items migrated (for reporting).
migrate_readme_to_backlog() {
  local repo="$1" backlog="$2"
  [ -f "$repo/README.md" ] || { echo 0; return; }
  [ "$DRY_RUN" -eq 1 ] && { echo 0; return; }

  local todo_section roadmap_section item count=0
  local in_todo=0 in_roadmap=0

  # Parse README for ## TODO and ## Roadmap sections.
  # This is a simple line-by-line parser; it does NOT handle nested markdown.
  # Items are lines starting with "- " or "* ".
  todo_section=""
  roadmap_section=""

  while IFS= read -r line; do
    if [ "$line" = "## TODO" ] || [ "$line" = "## Todo" ]; then
      in_todo=1
      in_roadmap=0
      continue
    fi
    if [ "$line" = "## Roadmap" ] || [ "$line" = "## ROADMAP" ]; then
      in_roadmap=1
      in_todo=0
      continue
    fi
    if printf '%s' "$line" | grep -q '^## '; then
      in_todo=0
      in_roadmap=0
      continue
    fi
    if [ "$in_todo" -eq 1 ] && printf '%s' "$line" | grep -qE '^[ \t]*[-*] '; then
      todo_section="$todo_section$(printf '%s\n' "$line" | sed 's/^[ \t]*[-*] //')"$'\n'
      count=$((count + 1))
    fi
    if [ "$in_roadmap" -eq 1 ] && printf '%s' "$line" | grep -qE '^[ \t]*[-*] '; then
      roadmap_section="$roadmap_section$(printf '%s\n' "$line" | sed 's/^[ \t]*[-*] //')"$'\n'
      count=$((count + 1))
    fi
  done <"$repo/README.md"

  # Append items to BACKLOG.md if any were found.
  if [ -n "$todo_section" ]; then
    {
      printf '\n## From README TODO\n\n'
      printf '%s' "$todo_section" | while IFS= read -r item; do
        [ -z "$item" ] && continue
        printf '| TBD | %s | todo | N/A | backlog |\n' "$item"
      done
    } >>"$backlog"
  fi

  if [ -n "$roadmap_section" ]; then
    {
      printf '\n## From README Roadmap\n\n'
      printf '%s' "$roadmap_section" | while IFS= read -r item; do
        [ -z "$item" ] && continue
        printf '| TBD | %s | todo | N/A | backlog |\n' "$item"
      done
    } >>"$backlog"
  fi

  if [ "$count" -eq 0 ]; then
    {
      printf '\n## From README\n\n'
      printf '<!-- No README ## TODO or ## Roadmap section was found in the original repo.\n'
      printf 'If you have roadmap items, add them to the BACKLOG.md table above, or run:\n'
      printf '  specify clarify\n'
      printf 'to scaffold content with AI assistance. -->\n'
    } >>"$backlog"
  fi

  echo "$count"
}

run_install() {
  local repo="$1"
  local existing
  existing="$(detect_existing_ai "$repo" | tr '\n' ' ' | sed 's/ *$//')"
  if [ -n "$existing" ] && [ "$FORCE" -ne 1 ]; then
    die "Repo already has AI files: $existing
Use 'sdd-harness standardize' to back them up and install fresh, or --force."
  fi

  local project branch stack
  project="$(project_name "$repo")"
  # symbolic-ref works even before the first commit; fails on detached HEAD.
  branch="$(git -C "$repo" symbolic-ref --short -q HEAD 2>/dev/null || true)"
  [ -z "$branch" ] && branch="develop"
  # Use provided --stack or default to 'generic'
  stack="${STACK:-generic}"

  log "Installing sdd-harness $VERSION into $repo"
  log "  Project name: $project"
  log "  Branch: $branch"
  log "  Stack: $stack"
  log "  Runtimes: $RUNTIMES"
  [ "$DRY_RUN" -eq 1 ] && log "  Mode: DRY RUN (no files will be written)"

  copy_tree "$TEMPLATES_DIR/.ai" "$repo/.ai"
  copy_tree "$TEMPLATES_DIR/tools" "$repo/tools"

  for r in $(echo "$RUNTIMES" | tr ',' ' '); do
    case "$r" in
      claude)  copy_file "$TEMPLATES_DIR/CLAUDE.md"  "$repo/CLAUDE.md" ;;
      codex)   copy_file "$TEMPLATES_DIR/AGENTS.md"  "$repo/AGENTS.md" ;;
      cursor)  copy_file "$TEMPLATES_DIR/.cursor/rules/sdd-harness.mdc" "$repo/.cursor/rules/sdd-harness.mdc" ;;
      copilot) copy_file "$TEMPLATES_DIR/.github/copilot-instructions.md" "$repo/.github/copilot-instructions.md" ;;
      gemini)  copy_file "$TEMPLATES_DIR/GEMINI.md" "$repo/GEMINI.md" ;;
    esac
  done

  if [ "$DRY_RUN" -ne 1 ]; then
    for f in "$repo/.ai/PRODUCT.md" "$repo/.ai/CONTEXT.md" "$repo/.ai/BACKLOG.md" \
             "$repo/.ai/BOOTSTRAP.md" "$repo/.ai/specs/PRD.md" "$repo/.ai/specs/glossary.md"; do
      [ -f "$f" ] && substitute_placeholders "$f" "$project" "$branch" "$stack"
    done
  fi

  if [ "$INSTALL_HOOK" -eq 1 ]; then
    if [ "$DRY_RUN" -eq 1 ]; then
      say "would run $repo/.ai/hooks/install.sh"
      say "would dry-run the SDD hook surface against tracked files"
    else
      ( cd "$repo" && ./.ai/hooks/install.sh ) || warn "Hook installer exited non-zero; check $repo/.ai/hooks/install.sh"
      glob_sanity_check "$repo"
    fi
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would write $repo/.ai/BOOTSTRAP.md (judgment-layer handoff prompt)"
    say "would migrate README TODO/Roadmap items to .ai/BACKLOG.md"
  else
    # Migrate README items to BACKLOG.md
    local migrated_count
    migrated_count="$(migrate_readme_to_backlog "$repo" "$repo/.ai/BACKLOG.md")"
  fi

  log ""
  log "Installation complete. Results:"
  log "  ✓ Stack: $stack"
  [ "$DRY_RUN" -ne 1 ] && [ "$migrated_count" -gt 0 ] && log "  ✓ Migrated $migrated_count items from README to BACKLOG.md"
  log "  ✓ BOOTSTRAP.md ready for AI handoff"
  log ""
  log "Next steps:"
  log "  1. Open $repo/.ai/BOOTSTRAP.md — it tells you (or your AI) how to fill"
  log "     PRODUCT/CONTEXT/BACKLOG/glossary from this repo. Delete it when done."
  log "  2. If a glob warning appeared above, review $repo/.ai/hooks/config.sh."
  log "  3. Read $repo/.ai/ROUTING.md (it tells any AI how to operate the project)."
}

# ---------- standardize ----------
backup_existing() {
  local repo="$1"
  local stamp; stamp="$(date +%Y%m%d-%H%M%S)"
  local backup_dir="$repo/.ai-backup-$stamp"
  log "Backing up existing AI files to $backup_dir/"
  [ "$DRY_RUN" -eq 1 ] && { say "mkdir $backup_dir && move existing AI files"; return; }
  mkdir -p "$backup_dir"
  for m in "${AI_MARKERS[@]}"; do
    if [ -e "$repo/$m" ]; then
      mv "$repo/$m" "$backup_dir/$(basename "$m")" 2>/dev/null || true
    fi
  done
}

run_standardize() {
  local repo="$1"
  local existing
  existing="$(detect_existing_ai "$repo" | tr '\n' ' ' | sed 's/ *$//')"
  if [ -z "$existing" ]; then
    log "No existing AI files detected. Routing to 'install'."
    run_install "$repo"
    return
  fi
  log "Existing AI files: $existing"
  if [ "$YES" -ne 1 ]; then
    if [ "$NON_INTERACTIVE" -eq 1 ]; then
      die "--non-interactive set and existing AI files present; pass --yes to proceed with backup + install."
    fi
    printf 'Proceed with backup + fresh install? [y/N] '
    read -r answer
    [ "$answer" = "y" ] || [ "$answer" = "Y" ] || die "Aborted by user."
  fi
  backup_existing "$repo"
  FORCE=1
  run_install "$repo"
}

# ---------- audit ----------
run_audit() {
  local repo="$1"
  local existing
  existing="$(detect_existing_ai "$repo")"
  log "sdd-harness audit — $repo"
  log "  version: $VERSION"
  log ""
  if [ -z "$existing" ]; then
    log "  No AI-layer files detected. Repo is ready for 'sdd-harness init'."
  else
    log "  Detected AI-layer files:"
    printf '%s\n' "$existing" | sed 's/^/    - /'
    log ""
    if [ -d "$repo/.ai" ]; then
      log "  .ai/ contents:"
      ( cd "$repo" && find .ai -maxdepth 2 -type f -not -name '.gitkeep' 2>/dev/null | sort | sed 's/^/    /' )
    fi
    log ""
    log "  To re-layer this repo, run: sdd-harness standardize $repo"
  fi
}

# ---------- init (auto-route) ----------
run_init() {
  local repo="$1"
  local existing
  existing="$(detect_existing_ai "$repo" | tr '\n' ' ' | sed 's/ *$//')"
  if [ -z "$existing" ]; then
    log "Fresh repo detected. Routing to 'install'."
    run_install "$repo"
  else
    log "Existing AI files detected. Routing to 'standardize'."
    run_standardize "$repo"
  fi
}

# ---------- dispatch ----------
# Handle --list-stacks before command dispatch
if [ "$LIST_STACKS" -eq 1 ]; then
  list_stacks
  exit 0
fi

case "$COMMAND" in
  init)         run_init "$TARGET_REPO" ;;
  install)      run_install "$TARGET_REPO" ;;
  standardize)  run_standardize "$TARGET_REPO" ;;
  audit)        run_audit "$TARGET_REPO" ;;
  --help|-h)    usage ;;
  --version)    echo "$VERSION" ;;
  *)            die "Unknown command: $COMMAND (try: sdd-harness --help)" ;;
esac
