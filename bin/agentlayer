#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
COMMAND="${1:-}"

TARGET_REPO=""
RUNTIMES=""
PROJECT_TYPE=""
PROJECT_NAME=""
GIT_NAME=""
GIT_EMAIL=""
REPORT_PATH=""

DRY_RUN=0
YES=0
NON_INTERACTIVE=0
APPLY_GIT_CONFIG=0
INSTALL_GIT_HOOK=1

usage() {
  cat <<'EOF'
agentlayer

Usage:
  agentlayer <command> [repo-path] [options]

Commands:
  audit         Inspect a repo and emit an agentlayer audit report
  install       Install a canonical .ai/ layer plus selected runtime adapters
  standardize   Audit + back up existing AI files + rewrite to the canonical layout

Options:
  --repo PATH              Target repository path
  --runtimes LIST          Comma-separated runtimes: codex,claude,copilot,cursor,generic,all
  --project-type TYPE      auto, android, ios, web, backend, generic
  --project-name NAME      Override detected project name
  --git-name NAME          Git author name to record in generated docs
  --git-email EMAIL        Git author email to record in generated docs
  --apply-git-config       Apply git user.name and user.email locally if provided
  --no-git-hook            Skip .githooks/pre-commit installation
  --report-path PATH       Write audit markdown to a custom path
  --dry-run                Print actions without writing files
  --yes                    Do not ask for confirmation
  --non-interactive        Fail instead of prompting for missing choices
  --help                   Show this help

Examples:
  agentlayer audit /path/to/repo
  agentlayer install /path/to/repo --runtimes codex,claude --project-type android
  agentlayer standardize /path/to/repo --runtimes all --yes
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'WARN: %s\n' "$*" >&2
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

ensure_command() {
  [ -n "$COMMAND" ] || {
    usage
    exit 1
  }
}

normalize_csv() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -d ' ' \
    | sed -e 's/^,*//' -e 's/,*$//' -e 's/,,*/,/g'
}

normalize_runtimes() {
  local value
  value="$(normalize_csv "$1")"

  if [ "$value" = "all" ]; then
    value="codex,claude,copilot,cursor,generic"
  fi

  printf '%s' "$value"
}

validate_runtimes() {
  local value item
  value="$1"
  [ -n "$value" ] || die "No runtimes selected"

  OLD_IFS="$IFS"
  IFS=','
  for item in $value; do
    case "$item" in
      codex|claude|copilot|cursor|generic)
        ;;
      *)
        IFS="$OLD_IFS"
        die "Unsupported runtime '$item'. Allowed: codex, claude, copilot, cursor, generic, all"
        ;;
    esac
  done
  IFS="$OLD_IFS"
}

has_runtime() {
  case ",$RUNTIMES," in
    *,"$1",*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

prompt_value() {
  local label="$1"
  local default_value="$2"
  local answer=""

  if [ "$NON_INTERACTIVE" -eq 1 ]; then
    [ -n "$default_value" ] && {
      printf '%s' "$default_value"
      return 0
    }
    die "Missing required value: $label"
  fi

  if [ -n "$default_value" ]; then
    printf '%s [%s]: ' "$label" "$default_value" >&2
  else
    printf '%s: ' "$label" >&2
  fi

  read -r answer
  if [ -z "$answer" ]; then
    answer="$default_value"
  fi
  printf '%s' "$answer"
}

prompt_yes_no() {
  local question="$1"
  local default_value="${2:-y}"
  local answer=""

  if [ "$YES" -eq 1 ]; then
    return 0
  fi

  if [ "$NON_INTERACTIVE" -eq 1 ]; then
    [ "$default_value" = "y" ] && return 0
    return 1
  fi

  if [ "$default_value" = "y" ]; then
    printf '%s [Y/n]: ' "$question" >&2
  else
    printf '%s [y/N]: ' "$question" >&2
  fi

  read -r answer
  if [ -z "$answer" ]; then
    answer="$default_value"
  fi

  case "$answer" in
    y|Y|yes|YES)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

require_target_repo() {
  [ -n "$TARGET_REPO" ] || die "Missing repo path. Use a positional path or --repo PATH"
  [ -d "$TARGET_REPO" ] || die "Repo path does not exist: $TARGET_REPO"
}

is_git_repo() {
  git -C "$TARGET_REPO" rev-parse --git-dir >/dev/null 2>&1
}

detect_project_type() {
  if [ -n "$PROJECT_TYPE" ] && [ "$PROJECT_TYPE" != "auto" ]; then
    printf '%s' "$PROJECT_TYPE"
    return 0
  fi

  if find "$TARGET_REPO" -maxdepth 3 \( -name 'settings.gradle' -o -name 'settings.gradle.kts' -o -name 'AndroidManifest.xml' \) | grep -q .; then
    printf 'android'
    return 0
  fi

  if find "$TARGET_REPO" -maxdepth 3 \( -name '*.xcodeproj' -o -name '*.xcworkspace' -o -name 'Package.swift' -o -name 'Podfile' \) | grep -q .; then
    printf 'ios'
    return 0
  fi

  if [ -f "$TARGET_REPO/package.json" ] || [ -f "$TARGET_REPO/pnpm-lock.yaml" ] || [ -f "$TARGET_REPO/yarn.lock" ]; then
    printf 'web'
    return 0
  fi

  if [ -f "$TARGET_REPO/go.mod" ] || [ -f "$TARGET_REPO/Cargo.toml" ] || [ -f "$TARGET_REPO/pyproject.toml" ]; then
    printf 'backend'
    return 0
  fi

  printf 'generic'
}

default_runtime_suggestion() {
  case "$PROJECT_TYPE" in
    android|ios|web|backend)
      printf 'codex,claude,generic'
      ;;
    *)
      printf 'generic'
      ;;
  esac
}

ensure_runtimes_selected() {
  if [ -n "$RUNTIMES" ]; then
    RUNTIMES="$(normalize_runtimes "$RUNTIMES")"
    validate_runtimes "$RUNTIMES"
    return 0
  fi

  if [ "$NON_INTERACTIVE" -eq 1 ]; then
    die "Missing --runtimes under --non-interactive. Pass --runtimes codex,claude,copilot,cursor,generic,all explicitly; no silent default is applied."
  fi

  RUNTIMES="$(prompt_value "Choose runtimes (codex, claude, copilot, cursor, generic, all)" "$(default_runtime_suggestion)")"
  RUNTIMES="$(normalize_runtimes "$RUNTIMES")"
  validate_runtimes "$RUNTIMES"
}

detect_git_name() {
  if [ -n "$GIT_NAME" ]; then
    printf '%s' "$GIT_NAME"
    return 0
  fi

  local value=""
  value="$(git -C "$TARGET_REPO" config user.name 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s' "$value"
    return 0
  fi

  value="$(git config --global user.name 2>/dev/null || true)"
  printf '%s' "$value"
}

detect_git_email() {
  if [ -n "$GIT_EMAIL" ]; then
    printf '%s' "$GIT_EMAIL"
    return 0
  fi

  local value=""
  value="$(git -C "$TARGET_REPO" config user.email 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s' "$value"
    return 0
  fi

  value="$(git config --global user.email 2>/dev/null || true)"
  printf '%s' "$value"
}

language_rule_name() {
  case "$PROJECT_TYPE" in
    android) printf 'kotlin' ;;
    ios) printf 'swift' ;;
    web) printf 'typescript' ;;
    backend) printf 'code' ;;
    *) printf 'code' ;;
  esac
}

ui_rule_name() {
  case "$PROJECT_TYPE" in
    android) printf 'compose' ;;
    ios) printf 'swiftui' ;;
    web) printf 'react' ;;
    *) printf 'ui' ;;
  esac
}

platform_summary() {
  case "$PROJECT_TYPE" in
    android)
      cat <<'EOF'
Android project expected to use Gradle, Kotlin, structured layers, coroutines/Flow, and either Jetpack Compose or XML-based UI.
EOF
      ;;
    ios)
      cat <<'EOF'
iOS project expected to use Swift, Xcode or Swift Package Manager, structured presentation/state layers, explicit concurrency boundaries, and SwiftUI or UIKit.
EOF
      ;;
    web)
      cat <<'EOF'
Web project expected to use a package manager, typed application code where possible, explicit routing, API boundaries, and component-driven UI.
EOF
      ;;
    backend)
      cat <<'EOF'
Backend project expected to use explicit service boundaries, clear domain/data separation, tests around business rules, and operational observability.
EOF
      ;;
    *)
      cat <<'EOF'
Generic software project. Fill in the exact architecture, delivery flow, and constraints after the first audit pass.
EOF
      ;;
  esac
}

ui_stack_label() {
  case "$PROJECT_TYPE" in
    android) printf 'Jetpack Compose / XML' ;;
    ios) printf 'SwiftUI / UIKit' ;;
    web) printf 'React / component UI' ;;
    backend) printf 'No primary UI layer' ;;
    *) printf 'Project specific' ;;
  esac
}

language_label() {
  case "$PROJECT_TYPE" in
    android) printf 'Kotlin' ;;
    ios) printf 'Swift' ;;
    web) printf 'TypeScript / JavaScript' ;;
    backend) printf 'Project specific backend language' ;;
    *) printf 'Project specific language' ;;
  esac
}

runtime_list_pretty() {
  printf '%s' "$RUNTIMES" | sed 's/,/, /g'
}

timestamp_now() {
  date '+%Y-%m-%d %H:%M:%S %z'
}

standardize_stamp() {
  date '+%Y%m%d-%H%M%S'
}

write_file() {
  local path="$1"
  local content="$2"
  local overwrite="${3:-1}"

  if [ -f "$path" ] && [ "$overwrite" -ne 1 ]; then
    warn "Skipping existing file: $path"
    return 0
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN write $path"
    return 0
  fi

  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$content" >"$path"
}

backup_path_if_exists() {
  local source_path="$1"
  local backup_root="$2"

  [ -e "$source_path" ] || return 0

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN backup $source_path -> $backup_root"
    return 0
  fi

  mkdir -p "$backup_root"
  cp -R "$source_path" "$backup_root/"
}

remove_path_if_exists() {
  local target_path="$1"

  [ -e "$target_path" ] || return 0

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN remove $target_path"
    return 0
  fi

  rm -rf "$target_path"
}

install_git_hook_if_needed() {
  [ "$INSTALL_GIT_HOOK" -eq 1 ] || return 0
  is_git_repo || return 0

  local hook_path="$TARGET_REPO/.githooks/pre-commit"
  local hook_content
  hook_content="$(render_pre_commit_hook)"
  write_file "$hook_path" "$hook_content" 1

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN chmod +x $hook_path"
    log "DRY-RUN git config core.hooksPath .githooks"
    return 0
  fi

  chmod +x "$hook_path"
  git -C "$TARGET_REPO" config core.hooksPath .githooks
}

apply_git_identity_if_needed() {
  [ "$APPLY_GIT_CONFIG" -eq 1 ] || return 0
  is_git_repo || return 0
  [ -n "$GIT_NAME" ] || return 0
  [ -n "$GIT_EMAIL" ] || return 0

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN git config user.name \"$GIT_NAME\""
    log "DRY-RUN git config user.email \"$GIT_EMAIL\""
    return 0
  fi

  git -C "$TARGET_REPO" config user.name "$GIT_NAME"
  git -C "$TARGET_REPO" config user.email "$GIT_EMAIL"
}

render_ai_readme() {
  cat <<EOF
# AI Control Plane

Canonical AI layer for \`$PROJECT_NAME\`.

This directory is the source of truth for how AI tools should reason about the project.
Runtime adapters such as \`AGENTS.md\`, \`CLAUDE.md\`, or \`.github/copilot-instructions.md\`
must stay thin and must not drift from what is defined here.

## Read Order

1. \`.ai/context.md\`
2. \`.ai/context/architecture.md\`
3. \`.ai/context/dependencies.md\`
4. \`.ai/context/features.md\`
5. \`.ai/context/repository.md\`
6. \`.ai/context/recent-changes.md\`
7. \`.ai/decision-framework.md\`
8. The relevant files under \`.ai/rules/\`, \`.ai/agents/\`, and \`.ai/skills/\`

## First Pass Workflow

If \`.ai/context.md\` still shows a pending bootstrap status or the context files are still generic templates,
run \`.ai/agents/agent-context-bootstrap.md\` before planning features or editing product code.

## Installed Runtimes

- $(
    if has_runtime codex; then printf '%s' '\`Codex\` via \`AGENTS.md\`'; fi
    if has_runtime claude; then
      if has_runtime codex; then printf '%s' ', '; fi
      printf '%s' '\`Claude Code\` via \`CLAUDE.md\`'
    fi
    if has_runtime copilot; then
      if has_runtime codex || has_runtime claude; then printf '%s' ', '; fi
      printf '%s' '\`GitHub Copilot\` via \`.github/\`'
    fi
    if has_runtime cursor; then
      if has_runtime codex || has_runtime claude || has_runtime copilot; then printf '%s' ', '; fi
      printf '%s' '\`Cursor\` via \`.cursor/rules/agentlayer.mdc\`'
    fi
    if has_runtime generic; then
      if has_runtime codex || has_runtime claude || has_runtime copilot || has_runtime cursor; then printf '%s' ', '; fi
      printf '%s' '\`Generic AI\` via \`AGENTLAYER.md\`'
    fi
  )

## Invariants

- Treat \`.ai/\` as canonical
- Do not duplicate routing logic in runtime adapters
- Prefer explicit repository conventions over generic advice
- Update \`.ai/context/recent-changes.md\` after meaningful work
- Keep feature memory in \`.ai/features/\` and archived plans/fixes in \`.ai/archive/\`
EOF
}

render_context_md() {
  cat <<EOF
# Project Context

## Summary

| Field | Value |
| --- | --- |
| Project | $PROJECT_NAME |
| Project Type | $PROJECT_TYPE |
| Language | $(language_label) |
| UI Stack | $(ui_stack_label) |
| Installed Runtimes | $(runtime_list_pretty) |
| Context Bootstrap Status | Pending first-pass grounding |
| Generated | $(timestamp_now) |

## Why This Exists

This file is the first-stop summary for any AI runtime working in the repository.
It should be updated when the architecture, workflow, or project scope changes materially.

## Expected Starting Assumptions

$(platform_summary)

## Immediate Follow-Up

- Run \`.ai/agents/agent-context-bootstrap.md\` to ground these files in the real repository
- Replace generic placeholders in the files under \`.ai/context/\`
- Document the actual module layout and feature inventory
- Record real anti-patterns and gotchas in \`.ai/context/recent-changes.md\`
- Keep the runtime adapters thin and aligned with \`.ai/\`
EOF
}

render_architecture_md() {
  case "$PROJECT_TYPE" in
    android)
      cat <<EOF
# Architecture

## Baseline

- Prefer a clear split between UI/presentation, domain, and data
- Keep UI state immutable and driven from a single state holder
- Keep network/storage mapping out of UI code
- Prefer small, feature-oriented modules or packages over giant shared buckets

## Android-Specific Notes

- Use \`ViewModel\` or an equivalent state holder for screen state
- Prefer coroutines and \`Flow\` for async streams
- Keep business rules in use cases or dedicated domain services
- If Compose is in use, keep composables declarative and move logic outward
- If XML is in use, document the migration line between legacy screens and Compose

## Fill This In

- Actual module graph
- Navigation ownership
- Dependency injection strategy
- Persistence boundaries
- Analytics ownership
- Offline or sync behaviors
EOF
      ;;
    ios)
      cat <<EOF
# Architecture

## Baseline

- Separate UI, state management, domain logic, and data access
- Keep navigation and async side effects explicit
- Avoid pushing business rules into views
- Prefer feature-local organization where possible

## iOS-Specific Notes

- Use a single state owner per screen or feature flow
- Keep SwiftUI views declarative and move mutable logic into dedicated types
- Prefer structured concurrency over ad hoc callback chains
- Mark UI-facing state owners with \`@MainActor\` when appropriate
- If UIKit is present, document the boundary with SwiftUI
- Make async, cancellation, and threading expectations explicit

## Fill This In

- Feature/module map
- Navigation model
- Service and repository ownership
- Persistence and sync model
- Testing seams
EOF
      ;;
    web)
      cat <<EOF
# Architecture

## Baseline

- Separate presentation, state, data fetching, and domain logic
- Keep route-level concerns explicit
- Keep server interaction and caching strategy documented
- Avoid hiding business rules in UI components

## Web-Specific Notes

- Document routing and layout ownership
- Document API client and server state management
- Document form handling, analytics, and error boundaries
- Clarify whether the project is SPA, SSR, SSG, or hybrid
EOF
      ;;
    backend)
      cat <<EOF
# Architecture

## Baseline

- Separate transport, domain logic, and persistence boundaries
- Make side effects explicit
- Keep handlers thin and business logic reusable
- Document data contracts and operational constraints

## Backend-Specific Notes

- Record service boundaries
- Record queue, cron, and async worker behavior
- Document auth, permissions, and audit logging
- Document deployment/runtime expectations
EOF
      ;;
    *)
      cat <<EOF
# Architecture

## Baseline

- Record how the project is split into modules, packages, or layers
- Explain where business logic belongs
- Explain where side effects belong
- Explain what an AI agent must not restructure blindly

## Fill This In

- Module map
- Data flow
- External integrations
- Testing seams
- Legacy zones and migration constraints
EOF
      ;;
  esac
}

render_dependencies_md() {
  cat <<EOF
# Dependencies

## Core Stack

- Language: $(language_label)
- UI: $(ui_stack_label)
- Build tooling: document the actual toolchain here

## What To Document

- Networking layer and API clients
- Persistence/storage layer
- Dependency injection framework or bootstrap pattern
- Analytics/observability tooling
- Background work or scheduling tooling
- Feature flags, remote config, or experimentation tools

## Rules

- Prefer existing project dependencies over introducing new ones casually
- Document why a dependency exists before expanding its use
- Record version-sensitive or migration-sensitive libraries
EOF
}

render_features_md() {
  cat <<EOF
# Feature Inventory

## Current State

Add the real product features here, grouped by business area.

Suggested columns:

| Feature | Status | Main Files/Modules | Notes |
| --- | --- | --- | --- |
| Example feature | Planned / Active / Legacy | path/to/feature | Replace with real data |

## Follow-Up

- Replace placeholders with the actual feature map
- Mark legacy, partially migrated, or high-risk areas
- Link reference features for reuse
EOF
}

render_repository_md() {
  cat <<EOF
# Repository Workflow

## Git Identity

| Field | Value |
| --- | --- |
| user.name | ${GIT_NAME:-[not detected]} |
| user.email | ${GIT_EMAIL:-[not detected]} |

## Branching

- Preferred model: \`main\` + \`develop\` + short-lived feature/fix/chore branches
- Never commit directly on \`main\`, \`develop\`, or \`master\`
- Branch names: \`feature/*\`, \`fix/*\`, \`chore/*\`, \`docs/*\`, \`refactor/*\`

## Commit Format

- Format: \`[branch_name] type: "title"\`
- Types: \`feat\`, \`fix\`, \`refactor\`, \`docs\`, \`chore\`, \`test\`, \`style\`
- Keep commits in English unless the team has documented another rule
- Do not add AI co-author trailers

## Hooks

- If enabled, the bootstrap installs \`.githooks/pre-commit\`
- The hook blocks direct commits on protected branches
- Git hooks path is set to \`.githooks\` for the local repository config

## Runtime Governance

- \`.ai/\` is canonical
- Runtime adapters must remain thin
- After significant work, update \`.ai/context/recent-changes.md\`
EOF
}

render_recent_changes_md() {
  cat <<EOF
# Recent Changes And Gotchas

## Recent Changes

| Date | Change | Notes |
| --- | --- | --- |
| $(date '+%Y-%m-%d') | agentlayer initialized | Replace with real repository changes |

## Known Gotchas

- Add platform- or repo-specific gotchas here
- Record recurring review issues here
- Record migration landmines here
EOF
}

render_decision_framework_md() {
  cat <<EOF
# Decision Framework

Use this table before changing code.

| Change Type | Expected Approach |
| --- | --- |
| New feature | Explore unfamiliar areas first, then plan files, tests, data contracts, state, and UI |
| Bug fix | Reproduce, isolate root cause, add a failing test when possible, then apply the smallest safe fix |
| Refactor | Add a safety net first, then change structure in verified increments |
| New endpoint or datasource | Define contract, mapper, repository/service boundary, error handling, and tests |
| UI migration | Isolate state and business logic first, then move the rendering layer |
| Analytics event | Define naming, payload, trigger point, and verification path |
| New dependency | Justify need, document risk, and prefer existing stack patterns |
| Legacy touchpoint | Minimize blast radius and document what should be migrated later |

If the change does not fit a documented pattern, add one after the work is understood.
EOF
}

render_language_rule_md() {
  case "$PROJECT_TYPE" in
    android)
      cat <<EOF
# Kotlin Rule

- Keep business logic out of UI classes and composables
- Prefer immutable UI state
- Prefer coroutines and \`Flow\` over ad hoc callbacks when the stack already uses them
- Keep file responsibilities narrow
- Make nullability and error handling explicit
EOF
      ;;
    ios)
      cat <<EOF
# Swift Rule

- Keep views declarative and business logic elsewhere
- Make state ownership explicit
- Prefer structured concurrency and \`async/await\`
- Use \`@MainActor\` for UI-facing state owners when the repo follows that pattern
- Keep async boundaries, cancellation, and actor hops clear
- Prefer small, testable units over giant view models or controllers
- Record migration constraints when touching legacy UIKit
EOF
      ;;
    web)
      cat <<EOF
# TypeScript Rule

- Keep domain logic out of rendering components
- Prefer explicit types at boundaries
- Make async state and error state explicit
- Avoid hidden side effects in shared utilities
- Favor small modules over giant catch-all files
EOF
      ;;
    *)
      cat <<EOF
# Code Rule

- Keep responsibilities narrow
- Keep business logic separate from transport and presentation
- Make side effects visible
- Prefer explicit contracts and tests at boundaries
EOF
      ;;
  esac
}

render_ui_rule_md() {
  case "$PROJECT_TYPE" in
    android)
      cat <<EOF
# Compose Rule

- Keep composables declarative
- Hoist state upward
- Avoid long side-effect chains inside composables
- Prefer preview or fake data paths for design-time verification
- Document whether each screen is Compose-only, XML-only, or mixed
EOF
      ;;
    ios)
      cat <<EOF
# SwiftUI Rule

- Keep views value-driven
- Move mutable state and business logic out of the view body
- Keep navigation ownership explicit
- Record any UIKit bridges or wrappers
- Prefer preview fixtures or sample data
- Keep async loading and error states explicit in the screen state model
EOF
      ;;
    web)
      cat <<EOF
# React Rule

- Keep rendering components simple
- Push data fetching and mutation logic to explicit hooks/services
- Keep state ownership obvious
- Avoid broad prop drilling when a documented pattern already exists
- Make loading, empty, and error states explicit
EOF
      ;;
    *)
      cat <<EOF
# UI Rule

- Keep rendering logic declarative where possible
- Separate UI concerns from business rules
- Document loading, empty, and error states
- Record any legacy rendering surfaces that need special care
EOF
      ;;
  esac
}

render_feature_rule_md() {
  cat <<EOF
# Feature Rule

- Organize new work by feature or domain whenever the repo supports it
- Reuse existing patterns before introducing a new structure
- Document the feature entry points, main state owner, and test seam
- Record analytics, navigation, and data dependencies explicitly
EOF
}

render_testing_rule_md() {
  cat <<EOF
# Testing Rule

- Add or update tests around behavior that is changing
- Prefer narrow tests around business rules and state transitions
- Add regression coverage before risky refactors
- Document any missing coverage you intentionally defer
EOF
}

render_analytics_rule_md() {
  cat <<EOF
# Analytics Rule

- Use the existing analytics naming and payload conventions
- Define event trigger points explicitly
- Avoid duplicating events across layers
- Record required verification steps when adding or changing events
EOF
}

render_data_rule_md() {
  cat <<EOF
# Data Rule

- Keep DTOs, storage entities, and domain models separate when the repo already distinguishes them
- Keep mapping logic out of UI code
- Make error handling and fallback behavior explicit
- Document ownership of caching, sync, and retry behavior
EOF
}

render_agent_explore_md() {
  cat <<EOF
# Agent: Explore

Use this flow when the area is unfamiliar.

## Output

- relevant files and modules
- current architecture pattern
- reusable reference implementation
- risks, constraints, and open questions

## Non-Goals

- do not implement code
- do not skip straight to a plan without evidence
EOF
}

render_agent_context_bootstrap_md() {
  cat <<EOF
# Agent: Context Bootstrap

Use this flow immediately after \`install\` or \`standardize\` when the canonical \`.ai/context*\` files are still template-generated.

## Mission

Ground the AI layer in the real repository before implementation work begins.

## Required Inputs

- repository root structure
- build and dependency files
- module or package boundaries
- test entry points and verification commands
- obvious feature areas
- known integration surfaces such as networking, persistence, analytics, and background work

## Update These Files

- \`.ai/context.md\`
- \`.ai/context/architecture.md\`
- \`.ai/context/dependencies.md\`
- \`.ai/context/features.md\`
- \`.ai/context/repository.md\`
- \`.ai/context/recent-changes.md\`

## Rules

- infer only from evidence in the repository
- do not invent architecture details you cannot support
- if something is unclear, leave an explicit open question instead of hallucinating
- do not implement product code in this pass unless the user explicitly asks for it
- identify the real test and build commands if they exist

## Completion Criteria

- \`.ai/context.md\` no longer reads like a generic template
- the architecture, dependencies, and features files reference real modules or paths
- \`Context Bootstrap Status\` in \`.ai/context.md\` is changed from pending to grounded
- \`.ai/context/recent-changes.md\` records that the first-pass context bootstrap happened
EOF
}

render_agent_feature_md() {
  cat <<EOF
# Agent: Feature Planning

Use this flow when the feature goal is known and implementation needs a concrete plan.

## Plan Must Include

- files or modules to touch
- state and data boundaries
- tests to add or update
- analytics, navigation, or operational impact if relevant
- rollout or migration considerations if relevant
EOF
}

render_agent_code_md() {
  cat <<EOF
# Agent: Code Execution

Use this flow to execute an approved plan in small verified steps.

## Rules

- stop on blocking failures
- keep the blast radius visible
- update feature memory after implementation
- update recent changes after meaningful edits
EOF
}

render_agent_verify_md() {
  cat <<EOF
# Agent: Verify

Use this flow after implementation or before merge.

## Output

- tests executed
- manual checks executed
- regressions found or ruled out
- remaining risks or deferred checks

## Rules

- verify the acceptance criteria, not only the code diff
- run the smallest meaningful regression set for the changed area
- call out what was not tested
- update \`.ai/context/recent-changes.md\` if behavior or constraints changed
EOF
}

render_agent_fix_md() {
  cat <<EOF
# Agent: Bug Fix

Use this flow for a well-defined defect.

## Rules

- reproduce first
- isolate root cause
- add a failing test when practical
- apply the smallest safe fix
- record the root cause in archive or recent changes
EOF
}

render_agent_tech_md() {
  cat <<EOF
# Agent: Technical Improvement

Use this flow for refactors, debt reduction, and structural cleanup.

## Rules

- define blast radius before changes
- add a safety net first
- change structure in small increments
- avoid user-visible behavior changes unless explicitly intended
EOF
}

render_agent_spike_md() {
  cat <<EOF
# Agent: Spike

Use this flow for time-boxed investigation.

## Output

- options considered
- effort and risk
- recommendation: proceed, pivot, or abandon
- suggested next task if work should continue
EOF
}

render_skill_context_refresh_md() {
  cat <<EOF
# Skill: Context Refresh

Regenerate or review:

- architecture summary
- dependency inventory
- feature inventory
- recent changes and gotchas

Use this at sprint start, after large merges, or before major planning.
EOF
}

render_skill_context_bootstrap_md() {
  cat <<EOF
# Skill: Context Bootstrap

Use this immediately after a fresh agentlayer install or standardize pass.

## Checklist

- identify the build system and primary entry points
- map modules, packages, or targets
- identify the real UI stack and state-management pattern
- identify the data layer, persistence layer, and integration surfaces
- identify test commands or test directories
- rewrite the generated \`.ai/context*\` files so they reflect the real repository
- leave explicit open questions where evidence is missing
EOF
}

render_skill_feature_scaffold_md() {
  cat <<EOF
# Skill: Feature Scaffold

Create the minimum feature boilerplate for this repository style.

## Expected Output

- feature entry point
- state owner
- data/domain contracts
- test skeleton
- placeholders for analytics and navigation
EOF
}

render_skill_migration_audit_md() {
  cat <<EOF
# Skill: Migration Audit

Use this to estimate and structure migrations such as:

- legacy UI to modern UI stack
- monolith to modular features
- callback flows to structured async flows
- weak repository boundaries to explicit domain/data layers
EOF
}

render_codex_adapter() {
  cat <<EOF
# Codex Adapter

Treat \`.ai/\` as canonical.

Read order:
1. \`.ai/README.md\`
2. \`.ai/context.md\`
3. \`.ai/context/architecture.md\`
4. \`.ai/context/dependencies.md\`
5. \`.ai/context/repository.md\`
6. \`.ai/decision-framework.md\`
7. The relevant files under \`.ai/rules/\`, \`.ai/agents/\`, and \`.ai/skills/\`

First pass rule:
- if \`.ai/context.md\` still shows \`Pending first-pass grounding\`, run \`.ai/agents/agent-context-bootstrap.md\` before implementation work

Do not maintain duplicate workflow logic here.
EOF
}

render_claude_adapter() {
  cat <<EOF
# Claude Adapter

Treat \`.ai/\` as canonical.

Read order:
1. \`.ai/README.md\`
2. \`.ai/context.md\`
3. \`.ai/context/architecture.md\`
4. \`.ai/context/dependencies.md\`
5. \`.ai/context/repository.md\`
6. \`.ai/decision-framework.md\`
7. The relevant files under \`.ai/rules/\`, \`.ai/agents/\`, and \`.ai/skills/\`

First pass rule:
- if \`.ai/context.md\` still shows \`Pending first-pass grounding\`, run \`.ai/agents/agent-context-bootstrap.md\` before implementation work

Do not duplicate routing, workflow, or checklists here.
EOF
}

render_copilot_adapter() {
  cat <<EOF
# Copilot Adapter

Treat \`.ai/\` as canonical.

Before editing:

1. Read \`.ai/README.md\`
2. Read \`.ai/context.md\`
3. Read \`.ai/context/architecture.md\`
4. Read \`.ai/context/dependencies.md\`
5. Read \`.ai/context/repository.md\`
6. Read \`.ai/decision-framework.md\`
7. Follow the matching instruction file in \`.github/instructions/\`

First pass rule:
- if \`.ai/context.md\` still shows \`Pending first-pass grounding\`, follow \`.ai/agents/agent-context-bootstrap.md\` before implementation work

Do not create a second source of truth under \`.github/\`.
EOF
}

render_cursor_adapter() {
  cat <<EOF
---
description: agentlayer adapter for Cursor
globs:
alwaysApply: true
---

Treat \`.ai/\` as canonical.

Read order:
1. \`.ai/README.md\`
2. \`.ai/context.md\`
3. \`.ai/context/architecture.md\`
4. \`.ai/context/dependencies.md\`
5. \`.ai/context/repository.md\`
6. \`.ai/decision-framework.md\`
7. The relevant files under \`.ai/rules/\`, \`.ai/agents/\`, and \`.ai/skills/\`

If \`AGENTLAYER.md\` exists, use it as the universal adapter layer for non-native runtimes.
If \`.ai/context.md\` still shows \`Pending first-pass grounding\`, run \`.ai/agents/agent-context-bootstrap.md\` first.
Do not duplicate workflow logic inside Cursor-specific files.
EOF
}

render_generic_adapter() {
  cat <<EOF
# Generic AI Adapter

Use this file when the runtime does not have a native repo adapter format, or when you want one universal entry point that works across multiple tools.

Treat \`.ai/\` as canonical.

## Read Order

1. \`.ai/README.md\`
2. \`.ai/context.md\`
3. \`.ai/context/architecture.md\`
4. \`.ai/context/dependencies.md\`
5. \`.ai/context/repository.md\`
6. \`.ai/decision-framework.md\`
7. The relevant files under \`.ai/rules/\`, \`.ai/agents/\`, and \`.ai/skills/\`

## Operating Rules

- Do not create a second source of truth outside \`.ai/\`
- Prefer existing project conventions over generic best practices
- If \`.ai/context.md\` still shows \`Pending first-pass grounding\`, run \`.ai/agents/agent-context-bootstrap.md\` first
- If key architecture details are still placeholders, audit the repo first and update \`.ai/context/\`
- After meaningful work, update \`.ai/context/recent-changes.md\`

## Suggested First Prompt

Audit this repository against the canonical \`.ai/\` layer, summarize the real architecture and gaps, and then propose the smallest safe set of updates before changing code.
EOF
}

render_copilot_instruction_wrapper() {
  local title="$1"
  local body="$2"
  cat <<EOF
# $title

Mirror of the canonical rule in \`.ai/rules/\`.
Keep this file aligned with the canonical source.

$body
EOF
}

render_pre_commit_hook() {
  cat <<'EOF'
#!/bin/bash
set -eu

if [ "${IMARK_SKIP_HOOK:-0}" = "1" ]; then
  exit 0
fi

BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null || true)"

if [ "$BRANCH" = "develop" ] || [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  if [ -f "$GIT_DIR/MERGE_HEAD" ] || [ -f "$GIT_DIR/SQUASH_MSG" ]; then
    exit 0
  fi

  echo ""
  echo "  BLOCKED: Direct commit on '$BRANCH' is not allowed."
  echo ""
  echo "  Create a short-lived branch first:"
  echo "    git checkout -b type/description"
  echo ""
  echo "  Bypass only for emergencies:"
  echo "    IMARK_SKIP_HOOK=1 git commit ..."
  echo ""
  exit 1
fi
EOF
}

write_canonical_files() {
  local overwrite="$1"
  local lang_rule ui_rule
  lang_rule="$(language_rule_name)"
  ui_rule="$(ui_rule_name)"

  write_file "$TARGET_REPO/.ai/README.md" "$(render_ai_readme)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context.md" "$(render_context_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context/architecture.md" "$(render_architecture_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context/dependencies.md" "$(render_dependencies_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context/features.md" "$(render_features_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context/repository.md" "$(render_repository_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/context/recent-changes.md" "$(render_recent_changes_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/decision-framework.md" "$(render_decision_framework_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/$lang_rule.md" "$(render_language_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/$ui_rule.md" "$(render_ui_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/feature.md" "$(render_feature_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/testing.md" "$(render_testing_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/analytics.md" "$(render_analytics_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/rules/data.md" "$(render_data_rule_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-explore.md" "$(render_agent_explore_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-context-bootstrap.md" "$(render_agent_context_bootstrap_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-plan.md" "$(render_agent_feature_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-code.md" "$(render_agent_code_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-verify.md" "$(render_agent_verify_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-fix.md" "$(render_agent_fix_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-tech.md" "$(render_agent_tech_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/agents/agent-spike.md" "$(render_agent_spike_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/skills/context-bootstrap.md" "$(render_skill_context_bootstrap_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/skills/context-refresh.md" "$(render_skill_context_refresh_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/skills/feature-scaffold.md" "$(render_skill_feature_scaffold_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/skills/migration-audit.md" "$(render_skill_migration_audit_md)" "$overwrite"
  write_file "$TARGET_REPO/.ai/features/.gitkeep" "" "$overwrite"
  write_file "$TARGET_REPO/.ai/archive/.gitkeep" "" "$overwrite"
}

write_runtime_adapters() {
  local overwrite="$1"
  local lang_rule ui_rule lang_body ui_body
  lang_rule="$(language_rule_name)"
  ui_rule="$(ui_rule_name)"
  lang_body="$(render_language_rule_md)"
  ui_body="$(render_ui_rule_md)"

  if has_runtime codex; then
    write_file "$TARGET_REPO/AGENTS.md" "$(render_codex_adapter)" "$overwrite"
  fi

  if has_runtime claude; then
    write_file "$TARGET_REPO/CLAUDE.md" "$(render_claude_adapter)" "$overwrite"
  fi

  if has_runtime copilot; then
    write_file "$TARGET_REPO/.github/copilot-instructions.md" "$(render_copilot_adapter)" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/$lang_rule.instructions.md" "$(render_copilot_instruction_wrapper "$lang_rule rule" "$lang_body")" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/$ui_rule.instructions.md" "$(render_copilot_instruction_wrapper "$ui_rule rule" "$ui_body")" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/feature.instructions.md" "$(render_copilot_instruction_wrapper "feature rule" "$(render_feature_rule_md)")" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/testing.instructions.md" "$(render_copilot_instruction_wrapper "testing rule" "$(render_testing_rule_md)")" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/analytics.instructions.md" "$(render_copilot_instruction_wrapper "analytics rule" "$(render_analytics_rule_md)")" "$overwrite"
    write_file "$TARGET_REPO/.github/instructions/data.instructions.md" "$(render_copilot_instruction_wrapper "data rule" "$(render_data_rule_md)")" "$overwrite"
  fi

  if has_runtime cursor; then
    write_file "$TARGET_REPO/.cursor/rules/agentlayer.mdc" "$(render_cursor_adapter)" "$overwrite"
  fi

  if has_runtime generic; then
    write_file "$TARGET_REPO/AGENTLAYER.md" "$(render_generic_adapter)" "$overwrite"
  fi
}

has_existing_ai_files() {
  [ -d "$TARGET_REPO/.ai" ] \
    || [ -f "$TARGET_REPO/AGENTS.md" ] \
    || [ -f "$TARGET_REPO/CLAUDE.md" ] \
    || [ -f "$TARGET_REPO/.github/copilot-instructions.md" ] \
    || [ -d "$TARGET_REPO/.github/instructions" ] \
    || [ -f "$TARGET_REPO/.cursor/rules/agentlayer.mdc" ] \
    || [ -f "$TARGET_REPO/AGENTLAYER.md" ]
}

build_audit_report() {
  local project_type_value git_repo_value recommendation
  project_type_value="$PROJECT_TYPE"
  git_repo_value="no"
  if is_git_repo; then
    git_repo_value="yes"
  fi

  if has_existing_ai_files; then
    recommendation="- Repository already has some AI-related files. Prefer \`standardize\` if you want a canonical \`.ai/\` layer plus aligned runtime adapters.
- Review existing docs before overwriting them."
  else
    recommendation="- Repository does not appear to have an agentlayer control plane yet. \`install\` is the right starting command."
  fi

  cat <<EOF
# agentlayer Audit Report

| Field | Value |
| --- | --- |
| Target Repo | $TARGET_REPO |
| Project Name | $PROJECT_NAME |
| Detected Project Type | $project_type_value |
| Git Repo | $git_repo_value |
| Selected Runtimes | ${RUNTIMES:-[not selected]} |
| Generated | $(timestamp_now) |

## Detected Files

| Path | Status |
| --- | --- |
| \`.ai/\` | $( [ -d "$TARGET_REPO/.ai" ] && printf 'present' || printf 'missing' ) |
| \`AGENTS.md\` | $( [ -f "$TARGET_REPO/AGENTS.md" ] && printf 'present' || printf 'missing' ) |
| \`CLAUDE.md\` | $( [ -f "$TARGET_REPO/CLAUDE.md" ] && printf 'present' || printf 'missing' ) |
| \`.github/copilot-instructions.md\` | $( [ -f "$TARGET_REPO/.github/copilot-instructions.md" ] && printf 'present' || printf 'missing' ) |
| \`.github/instructions/\` | $( [ -d "$TARGET_REPO/.github/instructions" ] && printf 'present' || printf 'missing' ) |
| \`.cursor/rules/agentlayer.mdc\` | $( [ -f "$TARGET_REPO/.cursor/rules/agentlayer.mdc" ] && printf 'present' || printf 'missing' ) |
| \`AGENTLAYER.md\` | $( [ -f "$TARGET_REPO/AGENTLAYER.md" ] && printf 'present' || printf 'missing' ) |
| \`.githooks/pre-commit\` | $( [ -f "$TARGET_REPO/.githooks/pre-commit" ] && printf 'present' || printf 'missing' ) |

## Recommendation

$recommendation
EOF
}

first_pass_prompt_codex() {
  cat <<'EOF'
Read AGENTS.md and the canonical .ai/ layer. Audit the repository, map the real architecture and dependencies, replace the placeholder AI context with repo-specific information, and only then propose the smallest safe implementation plan.
EOF
}

first_pass_prompt_claude() {
  cat <<'EOF'
Read CLAUDE.md and the canonical .ai/ layer. Summarize the real module layout, identify missing context, update the agentlayer docs so they match the repository, and then suggest the next safe changes.
EOF
}

first_pass_prompt_copilot() {
  cat <<'EOF'
Read .github/copilot-instructions.md and the canonical .ai/ layer. Audit the repository, replace the placeholder AI context with repo-specific information, and propose the smallest safe next change before editing code.
EOF
}

first_pass_prompt_cursor() {
  cat <<'EOF'
Follow .cursor/rules/agentlayer.mdc into the canonical .ai/ layer. Audit the repository, replace the placeholder AI context with repo-specific information, and propose the smallest safe next change before editing code.
EOF
}

first_pass_prompt_generic() {
  cat <<'EOF'
Read AGENTLAYER.md and .ai/README.md. Use the repository itself to infer the true architecture, dependencies, and workflows, update the placeholder AI context files, and propose a minimal-risk plan before making code changes.
EOF
}

print_paste_block() {
  local label="$1"
  local body="$2"
  local rule="────────────────────────────────────────────────────────────"
  log ""
  log "$rule"
  log "Paste this into $label"
  log "$rule"
  log "$body"
  log "$rule"
}

print_first_pass_guidance() {
  log ""
  log "Next recommended first pass — copy one of the prompts below into your AI."

  if has_runtime codex; then
    print_paste_block "Codex" "$(first_pass_prompt_codex)"
  fi

  if has_runtime claude; then
    print_paste_block "Claude Code" "$(first_pass_prompt_claude)"
  fi

  if has_runtime copilot; then
    print_paste_block "GitHub Copilot" "$(first_pass_prompt_copilot)"
  fi

  if has_runtime cursor; then
    print_paste_block "Cursor" "$(first_pass_prompt_cursor)"
  fi

  if has_runtime generic; then
    print_paste_block "Generic AI" "$(first_pass_prompt_generic)"
  fi
}

run_audit() {
  local report
  report="$(build_audit_report)"

  if [ -n "$REPORT_PATH" ]; then
    write_file "$REPORT_PATH" "$report" 1
  fi

  log "$report"
}

run_install() {
  if has_existing_ai_files; then
    die "AI-related files already exist in $TARGET_REPO. 'install' refuses to run against a repo with prior AI setup. Run 'agentlayer standardize' to migrate the existing layout to the canonical layer, or remove the existing files manually first."
  fi

  ensure_runtimes_selected

  write_canonical_files 0
  write_runtime_adapters 0
  install_git_hook_if_needed
  apply_git_identity_if_needed

  log "agentlayer install complete for $TARGET_REPO"
  print_first_pass_guidance
}

run_standardize() {
  ensure_runtimes_selected

  local backup_root
  backup_root="$TARGET_REPO/.ai/archive/standardize-$(standardize_stamp)"

  backup_path_if_exists "$TARGET_REPO/.ai" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/AGENTS.md" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/CLAUDE.md" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/.github/copilot-instructions.md" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/.github/instructions" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/.cursor/rules/agentlayer.mdc" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/AGENTLAYER.md" "$backup_root"
  backup_path_if_exists "$TARGET_REPO/.githooks/pre-commit" "$backup_root"

  remove_path_if_exists "$TARGET_REPO/.github/copilot-instructions.md"
  remove_path_if_exists "$TARGET_REPO/.github/instructions"
  remove_path_if_exists "$TARGET_REPO/.cursor/rules/agentlayer.mdc"

  if ! has_runtime codex; then
    remove_path_if_exists "$TARGET_REPO/AGENTS.md"
  fi

  if ! has_runtime claude; then
    remove_path_if_exists "$TARGET_REPO/CLAUDE.md"
  fi

  if ! has_runtime generic; then
    remove_path_if_exists "$TARGET_REPO/AGENTLAYER.md"
  fi

  write_canonical_files 1
  write_runtime_adapters 1
  install_git_hook_if_needed
  apply_git_identity_if_needed

  log "agentlayer standardization complete for $TARGET_REPO"
  print_first_pass_guidance
}

parse_args() {
  shift || true

  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        TARGET_REPO="${2:-}"
        shift 2
        ;;
      --runtimes)
        RUNTIMES="${2:-}"
        shift 2
        ;;
      --project-type)
        PROJECT_TYPE="${2:-}"
        shift 2
        ;;
      --project-name)
        PROJECT_NAME="${2:-}"
        shift 2
        ;;
      --git-name)
        GIT_NAME="${2:-}"
        shift 2
        ;;
      --git-email)
        GIT_EMAIL="${2:-}"
        shift 2
        ;;
      --report-path)
        REPORT_PATH="${2:-}"
        shift 2
        ;;
      --apply-git-config)
        APPLY_GIT_CONFIG=1
        shift
        ;;
      --no-git-hook)
        INSTALL_GIT_HOOK=0
        shift
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --yes)
        YES=1
        shift
        ;;
      --non-interactive)
        NON_INTERACTIVE=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        if [ -z "$TARGET_REPO" ]; then
          TARGET_REPO="$1"
          shift
        else
          die "Unknown argument: $1"
        fi
        ;;
    esac
  done
}

main() {
  ensure_command

  case "$COMMAND" in
    audit|install|standardize)
      ;;
    --help|-h|help)
      usage
      exit 0
      ;;
    *)
      usage
      die "Unknown command: $COMMAND"
      ;;
  esac

  parse_args "$@"
  require_target_repo
  TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"

  PROJECT_TYPE="$(detect_project_type)"

  if [ -z "$PROJECT_NAME" ]; then
    PROJECT_NAME="$(basename "$TARGET_REPO")"
  fi

  GIT_NAME="$(detect_git_name)"
  GIT_EMAIL="$(detect_git_email)"

  case "$COMMAND" in
    audit)
      run_audit
      ;;
    install)
      run_install
      ;;
    standardize)
      run_standardize
      ;;
  esac
}

main "$@"
